# Copy to .env and fill in. .env is gitignored.

# DataWhisk sensor data — external Postgres (read-only from our side).
# Spec default shown; replace USER/PASS/HOST with your real server.
DATABASE_URL=postgresql://user:pass@postgres:5432/datawhisk

# MLflow tracking server (internal, docker DNS). Do not change unless you
# rename the service in docker-compose.yml.
MLFLOW_TRACKING_URI=http://mlflow:5000

# Dagster (internal).
DAGSTER_HOME=/opt/dagster/dagster_home

# Dagster webserver target for the FastAPI GraphQL client.
# Use `dagster_webserver` inside docker; `localhost` if running the API on the host.
DAGSTER_WEBSERVER_HOST=dagster_webserver
DAGSTER_WEBSERVER_PORT=3000

# Local Postgres (Dagster + MLflow metadata). Matches infra/postgres/init.sql.
POSTGRES_USER=dw
POSTGRES_PASSWORD=dw
